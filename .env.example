# EarthLetter environment variables — see _workspace/00_architecture.md § 11.
# Copy to `.env` for local development. Never commit a real `.env`.

# --- Database (Supabase Postgres via Prisma) ---
# Pooler URL used at runtime by PrismaClient.
DATABASE_URL="postgresql://postgres:password@localhost:5432/earthletter?schema=public"

# Direct connection, used by `prisma migrate` (no PgBouncer).
DIRECT_URL="postgresql://postgres:password@localhost:5432/earthletter?schema=public"

# --- Ingestion auth ---
# Shared bearer between GitHub Actions and POST /api/ingest|prune.
# Generate with: `openssl rand -hex 32`. Rotate on leak.
INGEST_SECRET="replace-me-with-a-long-random-string"
# Note: INGEST_SECRET also gates /admin routes via session cookie (el_admin, HttpOnly, 24h)

# --- AdSense (public) ---
# Prefixed NUXT_PUBLIC_ so Nuxt exposes it via runtimeConfig.public.adsenseClient.
# Leave empty locally and in Preview envs to keep ad slots as placeholders.
# Only set after AdSense approval; scope to Production in Vercel.
NUXT_PUBLIC_ADSENSE_CLIENT=""

# --- Canonical site URL ---
# Used by @nuxtjs/sitemap, canonical tags, OG meta, and GH Actions ingest target.
SITE_URL="http://localhost:3000"
